{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch NearKart (Next.js)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 3000,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "ready in",
        "uriFormat": "http://localhost:3000"
      }
    }
  ]
}
